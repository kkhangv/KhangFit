# Upstash Redis (from Vercel Marketplace → Upstash Redis integration)
# https://vercel.com/marketplace?category=storage&search=upstash
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# App password (set this to whatever you want for login)
APP_PASSWORD=changeme

# Anthropic API key for AI-generated workout plans (Claude Haiku 4.5)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
